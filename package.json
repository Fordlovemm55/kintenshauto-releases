{
  "name": "kintenshauto",
  "version": "1.0.25",
  "description": "KINTENSHAUTO - เครื่องมือโพสต์ Reel อัตโนมัติสำหรับ Facebook",
  "main": "electron/main.js",
  "author": "KINTENSHAUTO Team",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "vite dev",
    "build-frontend": "vite build",
    "postinstall": "electron-builder install-app-deps && node scripts/download-deps.js",
    "check-deps": "node scripts/check-dependencies.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "pack": "npm run build-frontend && electron-builder --dir",
    "dist": "npm run build-frontend && electron-builder",
    "dist:win": "npm run build-frontend && electron-builder --win",
    "dist:mac": "npm run build-frontend && electron-builder --mac",
    "dist:linux": "npm run build-frontend && electron-builder --linux",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "better-sqlite3": "^12.10.0",
    "bgutils-js": "^3.2.0",
    "electron-updater": "^6.3.0",
    "express": "^4.19.2",
    "ghost-cursor": "^1.2.0",
    "jsdom": "^29.1.1",
    "node-cron": "^3.0.3",
    "puppeteer-core": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.8.3",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "msw": "^2.14.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "supertest": "^7.2.2",
    "vite": "^5.4.0",
    "vitest": "^1.6.1"
  },
  "build": {
    "appId": "com.kintenshauto.app",
    "productName": "KINTENSHAUTO",
    "copyright": "Copyright © 2026",
    "asar": true,
    "directories": {
      "output": "dist-installer",
      "buildResources": "assets"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "src/backend/**/*",
      "scripts/**/*",
      "schema.sql",
      "!node_modules/**/*test*/**",
      "!**/*.map"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Fordlovemm55",
        "repo": "kintenshauto-releases",
        "private": false,
        "releaseType": "release"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/ghost-cursor/**/*",
      "node_modules/puppeteer-core/**/*",
      "node_modules/puppeteer-extra/**/*",
      "node_modules/puppeteer-extra-plugin-stealth/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/win32",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "assets/",
        "to": "assets",
        "filter": [
          "*.png",
          "*.ico",
          "*.icns"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KINTENSHAUTO",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "deleteAppDataOnUninstall": false,
      "language": "1054"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Utility"
    }
  }
}
